{
  "name": "creditwatcher",
  "version": "0.1.0",
  "description": "macOS menu bar app and CLI to monitor Codex, Claude Code, and Cursor usage limits",
  "license": "MIT",
  "author": "Aleksei Artemiev",
  "repository": {
    "type": "git",
    "url": "https://github.com/aalksii/creditwatcher.git"
  },
  "homepage": "https://github.com/aalksii/creditwatcher#readme",
  "bugs": {
    "url": "https://github.com/aalksii/creditwatcher/issues"
  },
  "keywords": [
    "codex",
    "claude",
    "cursor",
    "usage",
    "quota",
    "macos",
    "menu-bar",
    "cli",
    "openai",
    "anthropic"
  ],
  "type": "module",
  "files": [
    "dist/",
    "media/screenshot.png",
    "!dist/macos/"
  ],
  "bin": {
    "creditwatcher": "./dist/cli.js"
  },
  "scripts": {
    "build": "mkdir -p dist && find dist -mindepth 1 -maxdepth 1 ! -name macos -exec rm -rf {} + && tsc && cp src/dashboard/index.html dist/dashboard/index.html",
    "prepack": "npm run build",
    "macos:dmg": "scripts/build-dmg.sh",
    "macos:uninstall": "scripts/uninstall-local.sh",
    "dev": "tsx src/cli.ts",
    "login": "tsx src/cli.ts login",
    "login:codex": "tsx src/cli.ts login codex",
    "login:claude": "tsx src/cli.ts login claude",
    "login:cursor": "tsx src/cli.ts login cursor",
    "status": "tsx src/cli.ts status",
    "status:codex": "tsx src/cli.ts status codex",
    "status:claude": "tsx src/cli.ts status claude",
    "status:cursor": "tsx src/cli.ts status cursor",
    "dashboard": "tsx src/cli.ts dashboard",
    "quota": "tsx src/cli.ts quota --json",
    "serve": "tsx src/cli.ts serve"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

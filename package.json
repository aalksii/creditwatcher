{
  "name": "creditwatcher",
  "version": "0.1.0",
  "description": "CLI to check Codex, Claude, and Cursor usage limits safely",
  "type": "module",
  "bin": {
    "creditwatcher": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/dashboard dist/dashboard",
    "dev": "tsx src/cli.ts",
    "login": "tsx src/cli.ts login",
    "login:codex": "tsx src/cli.ts login codex",
    "login:claude": "tsx src/cli.ts login claude",
    "login:cursor": "tsx src/cli.ts login cursor",
    "status": "tsx src/cli.ts status",
    "status:codex": "tsx src/cli.ts status codex",
    "status:claude": "tsx src/cli.ts status claude",
    "status:cursor": "tsx src/cli.ts status cursor",
    "dashboard": "tsx src/cli.ts dashboard",
    "quota": "tsx src/cli.ts quota --json",
    "serve": "tsx src/cli.ts serve"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
